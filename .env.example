# ============================================================
# Koffey.ai Environment Variables
# Copy this file to .env for local frontend development
# against your hosted Supabase project.
# ============================================================

# === REQUIRED: Supabase ===
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Recommended for remote setup script (or link your project with Supabase CLI)
SUPABASE_PROJECT_REF=your-project-ref
# Recommended for remote schema push. Use the Session pooler string from Connect for the easiest local setup.
SUPABASE_DB_URL=postgresql://postgres.your-project-ref:your-password@aws-0-your-region.pooler.supabase.com:5432/postgres
# Optional fallback if you prefer a direct IPv6 connection as SUPABASE_DB_URL.
# When both are set, setup will retry schema push with the pooler if the direct connection fails.
SUPABASE_POOLER_DB_URL=

# === REQUIRED: AI Provider (at least one) ===
# Primary: Kimi/Moonshot — strong tool-calling support
KIMI_API_KEY=
# Alternate name accepted by the shared AI provider code
MOONSHOT_API_KEY=
# Fallback: Groq — fast inference
GROQ_API_KEY=
# Optional: Anthropic Claude
ANTHROPIC_API_KEY=
# Optional: Google Gemini
GEMINI_API_KEY=

# AI provider priority (comma-separated, first available is used)
# Options: kimi, groq, anthropic, gemini
AI_PROVIDER_PRIORITY=kimi,groq

# === OPTIONAL: Hosted app URLs and CORS ===
# The setup script derives APP_URL / APP_BASE_URL / SITE_URL / CORS_ALLOWED_ORIGINS
# from VITE_APP_URL if you leave them blank.
VITE_APP_URL=http://localhost:5173
APP_URL=
APP_BASE_URL=
SITE_URL=
CORS_ALLOWED_ORIGINS=

# === OPTIONAL: Additional AI settings ===
OPENAI_API_KEY=

# === OPTIONAL: Google Integrations (Calendar, Gmail, Drive, OCR) ===
# Required if you want the "Connect Google Calendar", Gmail, or Drive flows to work.
# After filling these in, rerun `npm run setup` so Supabase edge-function secrets are updated.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CLOUD_VISION_API_KEY=

# === OPTIONAL: WhatsApp (via Twilio) ===
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=
CHANNEL_ID_HASH_SALT=
VITE_CHANNEL_ID_HASH_SALT=

# === OPTIONAL: Telegram ===
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_WEBHOOK_SECRET=

# === OPTIONAL: Email Sending (Resend) ===
RESEND_API_KEY=
RESEND_DOMAIN=
RESEND_FROM_EMAIL=

# === OPTIONAL: Voice ===
# Voice integration uses browser Web Speech API — no keys needed
